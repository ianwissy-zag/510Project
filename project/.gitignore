# Verilator build output directories
obj_*/
obj_dir/

# OpenLane run outputs
runs/

# Compiled binaries and object files
*.o
*.a
*.d

# Verilator-generated C++ (keep .sv and .cpp sources, not generated intermediates)
# (already covered by obj_*/)

# ASAP7 PDK — third-party repo, clone separately via git submodule
cadence/asap7/

# Large source files not suitable for git
Source/llm.c

# Cadence tool outputs — netlists are large and reproducible
cadence/*/outputs/
# reports are small and worth keeping
# cadence/*/reports/

# Genus log rotation files and temp directories
cadence/**/*.log[0-9]
cadence/**/.pbs_auto*/
