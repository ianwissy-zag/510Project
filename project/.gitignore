# Verilator build output directories
obj_*/
obj_dir/

# OpenLane run outputs
runs/

# Compiled binaries and object files
*.o
*.a
*.d

# Verilator-generated C++ (keep .sv and .cpp sources, not generated intermediates)
# (already covered by obj_*/)

# ASAP7 PDK — third-party repo, clone separately via git submodule
cadence/asap7/

# LLM source — ignore binary model/data files but track all source code
Source/llm/**/*.bin
Source/llm/*.bin

# LLM accel — ignore compiled binaries and weight dumps
Source/llm_accel/train_gpt2
Source/llm_accel/test_gpt2
Source/llm_accel/weights_accel.bin

# LLM — ignore compiled binaries and weight dumps
Source/llm/train_gpt2
Source/llm/weights_cpu.bin

# Cadence tool outputs — netlists are large and reproducible
cadence/*/outputs/
# reports are small and worth keeping
# cadence/*/reports/

# Genus log rotation files and temp directories
cadence/**/*.log[0-9]
cadence/**/.pbs_auto*/

# Genus formal verification outputs (large generated files)
cadence/**/fv/

# Profiling and performance data
Source/llm/perf.data
Source/llm/project_profile.txt
Source/llm_accel/perf.data
**/project_profile.txt
**/perf.data
